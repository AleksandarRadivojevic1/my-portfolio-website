# Resend (https://resend.com) API key used by app/actions/contact.ts to send
# contact-form submissions by email. The app builds and runs fine without
# this set — the contact form returns a graceful error instead of sending.
RESEND_API_KEY=

# Recipient address for contact-form submissions. Falls back to SITE.email
# (content/site.ts) when unset.
CONTACT_TO=
